---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Guidaro – Spezialist für Pflegebox & Hausnotruf Sales">

  <section class="hero">
    <div class="hero-bg-shape"></div>
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Spezialist für Pflegebox & Hausnotruf Sales
        </div>
        <h1>Mehr Verträge.<br><em>Weniger Aufwand.</em><br>Messbare Ergebnisse.</h1>
        <p class="lead">
          Guidaro kombiniert KI-Sprachagenten, geschulte Vertriebsmitarbeiter und ein proprietäres CRM — speziell entwickelt für Pflegebox- und Hausnotruf-Anbieter in Deutschland.
        </p>
        <div class="hero-actions">
          <a href="https://calendly.com/ahmed-guidaro/30min" target="_blank" class="btn-primary">
            Termin buchen — 30 Min
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </a>
          <a href="/branchen" class="btn-secondary">Unsere Branchen</a>
        </div>
        <div class="hero-stats">
          <div class="stat-card">
            <div class="stat-number">1.500+</div>
            <div class="stat-label">Anträge an Krankenkassen</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">100%</div>
            <div class="stat-label">Performance-basiert</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">0€</div>
            <div class="stat-label">Risiko für Partner</div>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <img src="/img/hero-illustration.svg" alt="Guidaro KI und Mensch Vertrieb" width="100%" />
        <div class="floating-badge fb-top">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00C48C" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
          Neuer Vertrag genehmigt
        </div>
        <div class="hero-card-main">
          <div class="hero-card-label">Guidaro Sales Pipeline — Live</div>
          <div class="pipeline-steps">
            <div class="pipeline-step done">
              <span class="step-icon">✓</span>
              KI-Erstkontakt
              <span class="step-meta">847 Anrufe heute</span>
            </div>
            <div class="pipeline-step done">
              <span class="step-icon">✓</span>
              Qualifizierung
              <span class="step-meta">312 qualifiziert</span>
            </div>
            <div class="pipeline-step active">
              <span class="step-icon">→</span>
              Beratungsgespräch
              <span class="step-meta">Läuft gerade…</span>
            </div>
            <div class="pipeline-step waiting">
              <span class="step-icon">○</span>
              Antragsstellung
              <span class="step-meta">Nächster Schritt</span>
            </div>
            <div class="pipeline-step waiting">
              <span class="step-icon">○</span>
              Genehmigung & Abschluss
              <span class="step-meta">In Bearbeitung</span>
            </div>
          </div>
        </div>
        <div class="floating-badge fb-bottom">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1756B8" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Ø 3,2 Tage bis Abschluss
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <p>Vertrauenspartner von</p>
    <div class="trust-logos">
      <span class="trust-logo">Pflegebox Deutschland</span>
      <span class="trust-sep">|</span>
      <span class="trust-logo">Hausnotruf Partner</span>
      <span class="trust-sep">|</span>
      <span class="trust-logo">KuraPaket</span>
      <span class="trust-sep">|</span>
      <span class="trust-logo">Weitere Anbieter</span>
    </div>
  </div>

  <!-- ZAHLEN SECTION -->
  <section class="zahlen-section">
    <div class="section-inner">
      <span class="section-tag">Bewiesene Ergebnisse</span>
      <h2>Zahlen, die für sich sprechen.</h2>
      <p class="lead">Keine Versprechen — echte Ergebnisse aus dem deutschen Pflegemarkt.</p>
      <div class="zahlen-grid">
        <div class="zahl-card zahl-card--hero">
          <div class="zahl-number">1.500+</div>
          <div class="zahl-label">Anträge an Krankenkassen</div>
          <div class="zahl-desc">Erfolgreich eingereichte Anträge für Pflegebox und Hausnotruf — geprüft, vollständig, genehmigungsfähig.</div>
        </div>
        <div class="zahl-card">
          <div class="zahl-number">100%</div>
          <div class="zahl-label">Performance-basiert</div>
          <div class="zahl-desc">Kein Fixum. Kein Risiko. Guidaro verdient ausschließlich bei Erfolg.</div>
        </div>
        <div class="zahl-card">
          <div class="zahl-number">2</div>
          <div class="zahl-label">Spezialbranchen</div>
          <div class="zahl-desc">Ausschließlich Pflegebox und Hausnotruf — tiefes Branchenwissen statt Generalist.</div>
        </div>
        <div class="zahl-card">
          <div class="zahl-number">24h</div>
          <div class="zahl-label">Antwortzeit</div>
          <div class="zahl-desc">Partneranfragen werden innerhalb von 24 Stunden beantwortet — schnell und verbindlich.</div>
        </div>
      </div>
    </div>
  </section>
  <section class="why-section">
    <div class="section-inner">
      <span class="section-tag">Warum Guidaro</span>
      <h2>Der Unterschied, der zählt.</h2>
      <p class="lead">Generische Callcenter kennen Ihren Markt nicht. Wir schon.</p>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🎯</div>
          <h3>100% Spezialisiert</h3>
          <p>Nur Pflegebox und Hausnotruf. Kein Ablenkung, maximale Tiefe in beiden Branchen.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🤖</div>
          <h3>KI + Mensch</h3>
          <p>KI für Skalierung, Menschen für Vertrauen. Die richtige Kombination für sensible Pflegethemen.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">⚡</div>
          <h3>Eigene Technologie</h3>
          <p>Proprietäres CRM speziell für Pflegebox & Hausnotruf — kein generisches System von der Stange.</p>
        </div>
        <div class="why-card">
          <div class="why-icon">🤝</div>
          <h3>Echtes Alignment</h3>
          <p>Wir verdienen nur, wenn Sie Erfolg haben. Vollständige Interessensübereinstimmung.</p>
        </div>
      </div>
      <div class="why-cta">
        <a href="/leistungen" class="btn-primary">Alle Leistungen ansehen →</a>
        <a href="/branchen" class="btn-secondary">Branchen entdecken</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #F0F5FF 0%, #FAFBFF 60%, #F0FDF8 100%);
    padding-top: 120px;
    position: relative;
    overflow: hidden;
    padding-left: 6vw;
    padding-right: 6vw;
  }
  .hero-bg-shape {
    position: absolute; right: -80px; top: 50%; transform: translateY(-50%);
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(23,86,184,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; max-width: 1200px; width: 100%; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: white; border: 1px solid var(--gray-200); border-radius: 40px;
    padding: 8px 16px; font-size: 13px; font-weight: 500; color: var(--navy);
    margin-bottom: 28px; box-shadow: var(--shadow);
  }
  .hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.6;transform:scale(1.3)} }
  h1 em { font-style: normal; color: var(--blue); }
  h1 { margin-bottom: 24px; }
  .hero-actions { display: flex; gap: 14px; margin-top: 36px; flex-wrap: wrap; }
  .hero-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 48px; }
  .stat-card { background: white; border: 1px solid var(--gray-200); border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow); }
  .stat-number { font-family: var(--font-head); font-size: 30px; font-weight: 700; color: var(--navy); }
  .stat-label { font-size: 12px; color: var(--gray-400); margin-top: 4px; }

  .hero-visual { position: relative; }
  .hero-card-main { background: white; border-radius: var(--radius-lg); border: 1px solid var(--gray-200); padding: 28px; box-shadow: var(--shadow-lg); }
  .hero-card-label { font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: var(--gray-400); margin-bottom: 16px; }
  .pipeline-steps { display: flex; flex-direction: column; gap: 10px; }
  .pipeline-step { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 10px; font-size: 14px; font-weight: 500; }
  .pipeline-step.active { background: var(--blue); color: white; }
  .pipeline-step.done { background: #ECFDF5; color: #065F46; }
  .pipeline-step.waiting { background: var(--gray-100); color: var(--gray-700); }
  .step-icon { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; background: rgba(255,255,255,0.2); }
  .step-meta { margin-left: auto; font-size: 12px; opacity: 0.7; }
  .floating-badge {
    position: absolute; background: white; border: 1px solid var(--gray-200);
    border-radius: var(--radius); padding: 12px 16px; box-shadow: var(--shadow-lg);
    font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; white-space: nowrap;
  }
  .fb-top { top: -24px; right: 20px; }
  .fb-bottom { bottom: -20px; left: 20px; }

  .trust-bar { background: var(--navy); padding: 32px 6vw; display: flex; align-items: center; justify-content: center; gap: 48px; flex-wrap: wrap; }
  .trust-bar > p { color: rgba(255,255,255,0.5); font-size: 12px; letter-spacing: 1px; text-transform: uppercase; }
  .trust-logos { display: flex; gap: 24px; align-items: center; flex-wrap: wrap; justify-content: center; }
  .trust-logo { color: rgba(255,255,255,0.6); font-size: 14px; font-weight: 600; font-family: var(--font-head); }
  .trust-sep { color: rgba(255,255,255,0.2); }

  .zahlen-section { background: var(--white); }
  .zahlen-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 20px; margin-top: 48px; }
  .zahl-card { background: var(--gray-100); border-radius: var(--radius-lg); padding: 28px; border: 1px solid var(--gray-200); }
  .zahl-card--hero { background: var(--navy); border-color: var(--navy); }
  .zahl-number { font-family: var(--font-head); font-size: 42px; font-weight: 700; color: var(--blue); letter-spacing: -1.5px; line-height: 1; margin-bottom: 8px; }
  .zahl-card--hero .zahl-number { font-size: 52px; color: var(--accent); }
  .zahl-label { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 10px; }
  .zahl-card--hero .zahl-label { color: var(--white); }
  .zahl-desc { font-size: 13px; color: var(--gray-700); line-height: 1.6; }
  .zahl-card--hero .zahl-desc { color: rgba(255,255,255,0.65); }

  .why-section { background: var(--gray-100); }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-top: 48px; margin-bottom: 40px; }
  .why-card { background: white; border-radius: var(--radius-lg); padding: 32px; border: 1px solid var(--gray-200); transition: all 0.25s; }
  .why-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--blue); }
  .why-icon { font-size: 32px; margin-bottom: 16px; }
  .why-cta { display: flex; gap: 14px; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
  }
</style>
