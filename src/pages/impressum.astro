---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum – Guidaro" description="Impressum und Anbieterkennzeichnung von Guidaro.">

  <section class="page-hero">
    <div class="section-inner">
      <span class="section-tag">Rechtliches</span>
      <h1>Impressum</h1>
    </div>
  </section>

  <section class="impressum-section">
    <div class="section-inner">
      <div class="impressum-card">

        <div class="impressum-block">
          <h3>Anbieter</h3>
          <p><strong>Guidaro</strong><br>
          01 Juni Str<br>
          Sekiet Ezzit, 3021<br>
          Sfax, Tunesien</p>
        </div>

        <div class="impressum-block">
          <h3>Kontakt</h3>
          <p>
            Telefon: <a href="tel:+4915679752011">+49 156 79752011</a><br>
            E-Mail: <a href="mailto:partner@usevoxera.com">partner@usevoxera.com</a><br>
            Web: <a href="https://usevoxera.com">usevoxera.com</a>
          </p>
        </div>

        <div class="impressum-block">
          <h3>Steuerliche Angaben</h3>
          <p>Tax ID: 1949907P</p>
        </div>

        <div class="impressum-block">
          <h3>Verantwortlich für den Inhalt</h3>
          <p>Ahmed Abida, Geschäftsführer</p>
        </div>

        <div class="impressum-block">
          <h3>Haftungshinweis</h3>
          <p style="font-size:14px; color:var(--gray-700); line-height:1.7;">
            Trotz sorgfältiger inhaltlicher Kontrolle übernehmen wir keine Haftung für die Inhalte externer Links. Für den Inhalt der verlinkten Seiten sind ausschließlich deren Betreiber verantwortlich.
          </p>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: linear-gradient(135deg, #F0F5FF 0%, #FAFBFF 100%); padding: 140px 6vw 60px; }
  .section-inner { max-width: 800px; margin: 0 auto; }
  .impressum-section { background: var(--gray-100); }
  .impressum-card { background: white; border-radius: var(--radius-lg); border: 1px solid var(--gray-200); padding: 48px; display: flex; flex-direction: column; gap: 32px; }
  .impressum-block h3 { font-size: 14px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
  .impressum-block p { font-size: 15px; color: var(--navy); line-height: 1.8; }
  .impressum-block a { color: var(--blue); text-decoration: none; }
  .impressum-block a:hover { text-decoration: underline; }
  .impressum-block + .impressum-block { border-top: 1px solid var(--gray-200); padding-top: 32px; }
</style>
