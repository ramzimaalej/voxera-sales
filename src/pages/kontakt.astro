---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt – Guidaro" description="Sprechen Sie mit uns über eine Partnerschaft für Pflegebox oder Hausnotruf Vertrieb.">

  <section class="page-hero">
    <div class="section-inner">
      <span class="section-tag">Kontakt</span>
      <h1>Bereit für<br>mehr Verträge?</h1>
      <p class="lead">Sprechen Sie mit uns über eine Partnerschaft. Kostenlos, unverbindlich — in der Regel antworten wir innerhalb von 24 Stunden.</p>
    </div>
  </section>

  <section class="kontakt-section">
    <div class="section-inner">
      <div class="kontakt-grid">
        <div>
          <div class="kontakt-info">
            <div class="kontakt-item">
              <div class="kontakt-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h4>Telefon</h4>
                <p>+49 156 79752011</p>
              </div>
            </div>
            <div class="kontakt-item">
              <div class="kontakt-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <h4>E-Mail</h4>
                <p>sales@guidaro.io</p>
              </div>
            </div>
            <div class="kontakt-item">
              <div class="kontakt-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
              <div>
                <h4>Region</h4>
                <p>Deutschland bundesweit</p>
              </div>
            </div>
          </div>

          <div class="erwartungen-card">
            <h3>Was Sie erwartet</h3>
            <ul>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-dark)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                30-Minuten Kennlerngespräch
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-dark)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                Individuelle Potenzialanalyse für Ihr Gebiet
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-dark)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                Transparente Kooperationskonditionen
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-dark)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                Kein Risiko — reines Performance-Modell
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent-dark)" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                Antwort innerhalb von 24 Stunden
              </li>
            </ul>
          </div>

          <a href="https://calendly.com/ahmed-guidaro/30min" target="_blank" class="calendly-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Jetzt Termin buchen — 30 Min kostenlos
          </a>
          <p class="calendly-note">Direkt in Ihren Kalender — kein Hin-und-Her per E-Mail</p>
        </div>

        <div class="kontakt-form">
          <h3>Partnerschaft anfragen</h3>
          <form id="contactForm">
            <div class="form-row">
              <div class="form-group">
                <label for="vorname">Vorname *</label>
                <input type="text" id="vorname" placeholder="Max" required />
              </div>
              <div class="form-group">
                <label for="nachname">Nachname *</label>
                <input type="text" id="nachname" placeholder="Mustermann" required />
              </div>
            </div>
            <div class="form-group">
              <label for="unternehmen">Unternehmen *</label>
              <input type="text" id="unternehmen" placeholder="Muster GmbH" required />
            </div>
            <div class="form-group">
              <label for="email">E-Mail-Adresse *</label>
              <input type="email" id="email" placeholder="max@muster.de" required />
            </div>
            <div class="form-group">
              <label for="telefon">Telefon</label>
              <input type="tel" id="telefon" placeholder="+49 ..." />
            </div>
            <div class="form-group">
              <label for="bereich">Bereich *</label>
              <select id="bereich" required>
                <option value="">Bitte wählen...</option>
                <option>Pflegebox-Anbieter</option>
                <option>Hausnotruf-Anbieter</option>
                <option>Beides</option>
                <option>Sonstiges</option>
              </select>
            </div>
            <div class="form-group">
              <label for="nachricht">Nachricht</label>
              <textarea id="nachricht" placeholder="Beschreiben Sie kurz Ihr Anliegen oder Ihr Vertriebsgebiet..."></textarea>
            </div>
            <button type="submit" class="form-submit" id="submitBtn">Anfrage senden →</button>
            <p class="form-note">Wir antworten innerhalb von 24 Stunden. Keine unerwünschten Nachrichten.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: linear-gradient(135deg, #F0F5FF 0%, #FAFBFF 100%); padding: 140px 6vw 80px; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .kontakt-section { background: var(--gray-100); }
  .kontakt-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 64px; align-items: start; }
  .kontakt-info { display: flex; flex-direction: column; gap: 20px; margin-bottom: 32px; }
  .kontakt-item { display: flex; gap: 14px; align-items: flex-start; }
  .kontakt-icon { width: 44px; height: 44px; background: var(--blue-pale); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .kontakt-icon svg { width: 20px; height: 20px; }
  .kontakt-item h4 { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 2px; }
  .kontakt-item p { font-size: 14px; color: var(--gray-700); }
  .erwartungen-card { background: var(--blue-pale); border-radius: var(--radius-lg); padding: 28px; border-left: 4px solid var(--blue); }
  .erwartungen-card h3 { margin-bottom: 16px; }
  .erwartungen-card ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .erwartungen-card li { display: flex; gap: 10px; align-items: center; font-size: 14px; color: var(--gray-700); }
  .kontakt-form { background: white; border-radius: var(--radius-lg); padding: 40px; box-shadow: var(--shadow); border: 1px solid var(--gray-200); }
  .kontakt-form h3 { margin-bottom: 24px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .form-group label { font-size: 13px; font-weight: 600; color: var(--navy); }
  .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px 16px; border: 1.5px solid var(--gray-200); border-radius: 10px; font-family: var(--font-body); font-size: 14px; color: var(--navy); background: white; outline: none; transition: border-color 0.2s; }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus { border-color: var(--blue); }
  .form-group textarea { height: 100px; resize: vertical; }
  .form-submit { width: 100%; background: var(--blue); color: white; border: none; padding: 14px; border-radius: 10px; font-family: var(--font-body); font-size: 15px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .form-submit:hover { background: var(--blue-light); transform: translateY(-1px); }
  .form-submit:disabled { background: var(--accent-dark); cursor: default; transform: none; }
  .form-note { font-size: 12px; color: var(--gray-400); text-align: center; margin-top: 12px; }
  .calendly-btn { display: flex; align-items: center; gap: 10px; margin-top: 16px; background: var(--accent); color: white; padding: 14px 20px; border-radius: 10px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s; justify-content: center; }
  .calendly-btn:hover { background: var(--accent-dark); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(0,196,140,0.3); }
  .calendly-note { font-size: 12px; color: var(--gray-400); text-align: center; margin-top: 8px; }
</style>

<script>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn') as HTMLButtonElement;
    btn.textContent = '✓ Anfrage gesendet!';
    btn.disabled = true;
  });
</script>
